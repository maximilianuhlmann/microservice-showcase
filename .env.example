# Environment Variables Example
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control

# PostgreSQL Database Configuration
POSTGRES_DB=usagebillingdb
POSTGRES_USER=usagebilling
POSTGRES_PASSWORD=your-secure-db-password

# Admin Console Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password

# API Keys (comma-separated)
API_KEYS=your-api-key-1,your-api-key-2
API_KEY_MAPPING=your-api-key-1=customer-1,your-api-key-2=customer-2

# Billing Scheduler
BILLING_SCHEDULER_ENABLED=false
BILLING_SCHEDULER_CRON=0 0 1 * * ?

# SonarQube Database Configuration (optional)
SONARQUBE_DB_NAME=sonar
SONARQUBE_DB_USER=sonar
SONARQUBE_DB_PASSWORD=your-secure-sonarqube-db-password
