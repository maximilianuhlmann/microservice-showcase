meta {
  name: Record Usage Event - Compute
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/usage-events
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-API-Key: {{apiKey}}
}

body:json {
  {
    "customerId": "{{customerId}}",
    "serviceType": "compute",
    "quantity": 2.5,
    "unit": "hours",
    "metadata": "{\"instance\":\"t2.medium\"}"
  }
}



