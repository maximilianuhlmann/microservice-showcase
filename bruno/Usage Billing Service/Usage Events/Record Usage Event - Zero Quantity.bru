meta {
  name: Record Usage Event - Zero Quantity
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/v1/usage-events
  body: json
  auth: none
}

headers {
  X-API-Key: {{apiKey}}
  Content-Type: application/json
}

body:json {
  {
    "customerId": "{{customerId}}",
    "serviceType": "api-calls",
    "quantity": 0,
    "unit": "requests"
  }
}

