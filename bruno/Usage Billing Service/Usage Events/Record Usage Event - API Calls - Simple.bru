meta {
  name: Record Usage Event - API Calls (Simple)
  type: http
  seq: 0
}

post {
  url: {{baseUrl}}/api/v1/usage-events
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-API-Key: {{apiKey}}
}

body:json {
  {
    "customerId": "{{customerId}}",
    "serviceType": "api-calls",
    "quantity": 1000,
    "unit": "requests"
  }
}

